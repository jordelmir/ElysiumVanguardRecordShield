<?xml version="1.0" encoding="utf-8"?>
<!--
  Data Extraction Rules — Elysium Vanguard Record Shield
  
  Why all deny: Evidence files must NEVER be included in device backups.
  This prevents cloud backup services (Google Drive, Samsung Cloud) from
  inadvertently exposing evidence files to other devices or accounts.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
